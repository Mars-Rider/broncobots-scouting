rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Configuration - readable by authenticated users, writable by admins
    match /configuration/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'lmckenna27@brophybroncos.org';
    }
    
    // Entries - readable/writable by authenticated users
    match /entries/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // History - readable by authenticated users, writable by admins
    match /history/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'lmckenna27@brophybroncos.org';
    }
  }
}

